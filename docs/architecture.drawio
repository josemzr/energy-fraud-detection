        <mxCell id="e_def" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#2e8b87;" edge="1" parent="1" source="defcloud" target="defxdr"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Foundry container -->
        <mxCell id="foundry" value="Microsoft Foundry — Agent Service (LangGraph Hosted Agents · model gpt-4.1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontStyle=1;fontSize=12;" vertex="1" parent="1">
