# Energy Fraud Detection — environment configuration (TEMPLATE)
# Copy to .env and fill in. NEVER commit a real .env.

# --- Microsoft Foundry (new Foundry project, hosted agents) ---
FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1

# --- Databricks Model Serving (energy-theft-detector ML model) ---
MODEL_SERVING_ENDPOINT=https://<workspace>.azuredatabricks.net/serving-endpoints/energy-theft-detector/invocations
MODEL_SERVING_TOKEN=<databricks-pat>
MODEL_SERVING_TIMEOUT=90

# --- Azure AI Search (energy regulations index) ---
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<search-key>
REGULATIONS_INDEX_NAME=regulations-policies

# --- Databricks Genie (NL-to-SQL over Lakehouse, via MCP) ---
DATABRICKS_WORKSPACE_HOSTNAME=<workspace>.azuredatabricks.net
GENIE_SPACE_ID=<genie-space-id>

# --- Fraud Alert MCP server (via APIM) ---
MCP_SERVER_ENDPOINT=<mcp-endpoint>
APIM_SUBSCRIPTION_KEY=<apim-key>

# --- Azure AI Content Safety (Prompt Shields — security guardrail) ---
CONTENT_SAFETY_ENDPOINT=https://<content-safety>.cognitiveservices.azure.com
CONTENT_SAFETY_KEY=<content-safety-key>

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=<app-insights-connection-string>
